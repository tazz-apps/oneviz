# OneViz Scraper — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# LLM providers (at least one required)
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Google Places API (required for scout.js)
# Enable "Places API (New)" in Google Cloud Console → APIs & Services
GOOGLE_PLACES_API_KEY=

# Cloudflare Pages (required for --deploy)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Netlify (optional — fallback via --deploy-netlify only)
NETLIFY_API_TOKEN=
